@model SV22T1020439.Models.ProductSearchResult
@{
    ViewBag.Title = "Trang chủ";
}

<div class="row">
    <div class="col-md-3">
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-list-task"></i> Danh mục
            </div>
            <div class="list-group list-group-flush">
                <a href="~/Home/Index?categoryID=0" class="list-group-item list-group-item-action @(Model.CategoryID == 0 ? "active" : "")">
                    Tất cả sản phẩm
                </a>
                @foreach (var c in SV22T1020439.BusinessLayers.CommonDataService.ListOfCategories())
                {
                    <a href="~/Home/Index?categoryID=@c.CategoryID" class="list-group-item list-group-item-action @(Model.CategoryID == c.CategoryID ? "active" : "")">
                        @c.CategoryName
                    </a>
                }
            </div>
        </div>
    </div>

    <div class="col-md-9">
        <div class="card mb-4 shadow-sm">
            <div class="card-body">
                <form action="~/Home/Index" method="get">
                    <input type="hidden" name="categoryID" value="@Model.CategoryID" />
                    <div class="row g-3">
                        <div class="col-md-5">
                            <label class="form-label small fw-bold">Tìm kiếm theo tên</label>
                            <input type="text" name="searchValue" class="form-control" placeholder="Tên sản phẩm..." value="@Model.SearchValue">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-bold">Giá từ</label>
                            <input type="text" name="minPrice" class="form-control" placeholder="0" value="@(Model.MinPrice > 0 ? Model.MinPrice.ToString("N0") : "")">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-bold">đến</label>
                            <input type="text" name="maxPrice" class="form-control" placeholder="999.999.999" value="@(Model.MaxPrice > 0 ? Model.MaxPrice.ToString("N0") : "")">
                        </div>
                        <div class="col-md-1 d-flex align-items-end">
                            <button class="btn btn-primary w-100" type="submit">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var item in Model.Data)
            {
                <div class="col">
                    <div class="card product-card h-100 shadow-sm border-0">
                        <div class="position-relative overflow-hidden" style="height: 220px; background: #f8f9fa;">
                            <img src="@(string.IsNullOrEmpty(item.Photo) ? "/images/products/default.png?v=" + DateTime.Now.Ticks : "/images/products/" + item.Photo)" 
                                 class="card-img-top w-100 h-100 p-2" 
                                 alt="@item.ProductName" 
                                 style="object-fit: contain; transition: transform 0.3s ease-in-out;"
                                 onmouseover="this.style.transform='scale(1.1)'"
                                 onmouseout="this.style.transform='scale(1.0)'"
                                 onerror="this.src='/images/products/default.png?v=@DateTime.Now.Ticks'; this.onerror=null;">
                        </div>
                        <div class="card-body d-flex flex-column p-3">
                            <h6 class="card-title fw-bold text-dark mb-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 2.5rem;">
                                @item.ProductName
                            </h6>
                            <div class="mt-auto">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="text-danger fw-bold fs-5">
                                        @item.Price.ToString("N0") <small>đ</small>
                                    </span>
                                    <small class="text-muted">/ @item.Unit</small>
                                </div>
                                <div class="row g-2">
                                    <div class="col-5">
                                        <a href="~/Product/Details/@item.ProductID" class="btn btn-outline-primary btn-sm w-100">
                                            Chi tiết
                                        </a>
                                    </div>
                                    <div class="col-7">
                                        <form method="post" action="~/Cart/AddToCart" class="d-inline w-100">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="productId" value="@item.ProductID" />
                                            <input type="hidden" name="quantity" value="1" />
                                            <button type="submit" class="btn btn-primary btn-sm w-100">
                                                <i class="bi bi-cart-plus"></i> Mua ngay
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Model.PageCount > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    @for (int p = 1; p <= Model.PageCount; p++)
                    {
                        <li class="page-item @(p == Model.Page ? "active" : "")">
                            <a class="page-link" href="~/Home/Index?page=@p&categoryID=@Model.CategoryID&searchValue=@Model.SearchValue&minPrice=@Model.MinPrice.ToString("N0")&maxPrice=@Model.MaxPrice.ToString("N0")">@p</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>

@section Scripts {
    <script>
        function addToCart(productId) {
            $.ajax({
                url: '/Cart/AddToCart',
                type: 'POST',
                data: { productId: productId, quantity: 1 },
                success: function(result) {
                    if (result.success) {
                        updateCartCount();
                    } else {
                        alert(result.message);
                    }
                }
            });
        }
    </script>
}
