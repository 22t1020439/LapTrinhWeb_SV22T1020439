@model SV22T1020439.Models.Customer
@{
    ViewBag.Title = "Thông tin cá nhân";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white py-3">
                <h4 class="mb-0"><i class="bi bi-person-bounding-box"></i> Thông tin tài khoản</h4>
            </div>
            <div class="card-body p-4">
                <form action="~/Account/UpdateProfile" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="CustomerID" value="@Model.CustomerID" />
                    <input type="hidden" name="IsLocked" value="@Model.IsLocked.ToString().ToLower()" />

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small uppercase">Họ tên khách hàng</label>
                            <input type="text" name="CustomerName" class="form-control form-control-lg border-0 bg-light" value="@Model.CustomerName" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small uppercase">Tên giao dịch</label>
                            <input type="text" name="ContactName" class="form-control form-control-lg border-0 bg-light" value="@Model.ContactName" required>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small uppercase">Email (Tên đăng nhập)</label>
                            <input type="email" name="Email" class="form-control form-control-lg border-0 bg-light-subtle" value="@Model.Email" readonly>
                            <small class="text-muted italic">Email dùng để đăng nhập và không thể thay đổi</small>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small uppercase">Số điện thoại</label>
                            <input type="tel" name="Phone" class="form-control form-control-lg border-0 bg-light" value="@Model.Phone">
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-muted small uppercase">Địa chỉ nhận hàng</label>
                        <input type="text" name="Address" class="form-control form-control-lg border-0 bg-light" value="@Model.Address">
                    </div>

                    <div class="mb-5">
                        <label class="form-label fw-bold text-muted small uppercase">Tỉnh / Thành phố</label>
                        <select name="Province" class="form-select form-select-lg border-0 bg-light">
                            @foreach (var p in SV22T1020439.BusinessLayers.CommonDataService.ListOfProvinces())
                            {
                                <option value="@p.ProvinceName" selected="@(p.ProvinceName == Model.Province)">@p.ProvinceName</option>
                            }
                        </select>
                    </div>

                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center border-top pt-4">
                        <a href="~/Account/ChangePassword" class="btn btn-link text-warning text-decoration-none mb-3 mb-md-0">
                            <i class="bi bi-shield-lock"></i> Đổi mật khẩu bảo mật
                        </a>
                        <button type="submit" class="btn btn-primary btn-lg px-5 shadow">
                            <i class="bi bi-check2-circle"></i> Cập nhật thông tin
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-light { background-color: #f8fafc !important; }
    .bg-light-subtle { background-color: #f1f5f9 !important; }
    .form-control-lg, .form-select-lg { font-size: 1rem; }
    .uppercase { text-transform: uppercase; letter-spacing: 0.5px; }
    .italic { font-style: italic; font-size: 0.8rem; }
</style>
