@model SV22T1020439.Models.Customer
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Đăng ký tài khoản - SV22 SHOP</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --primary-color: #F97316;
            --secondary-color: #FFF7ED;
            --text-color: #334155;
            --accent-color: #EA580C;
        }
        body { background-color: var(--secondary-color); color: var(--text-color); }
        .register-box { width: 450px; margin: 50px auto; }
        .card { border: none; box-shadow: 0 10px 25px rgba(249, 115, 22, 0.1); }
        .card-header { background-color: var(--primary-color) !important; border: none; }
        .btn-primary { background-color: var(--primary-color) !important; border: none; }
        .btn-primary:hover { background-color: var(--accent-color) !important; }
        .form-control:focus, .form-select:focus { border-color: var(--primary-color); box-shadow: 0 0 0 0.25rem rgba(249, 115, 22, 0.1); }
        a { color: var(--primary-color); text-decoration: none; }
        a:hover { color: var(--accent-color); text-decoration: underline; }
    </style>
</head>
<body>
    <div class="register-box">
        <div class="card shadow">
            <div class="card-header bg-primary text-white text-center py-3">
                <h4 class="mb-0">Đăng ký tài khoản</h4>
            </div>
            <div class="card-body p-4">
                <form action="~/Account/Register" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div class="mb-3">
                        <label class="form-label">Họ tên khách hàng</label>
                        <input type="text" name="CustomerName" class="form-control" value="@Model.CustomerName" required>
                        <span class="text-danger small">@Html.ValidationMessage("CustomerName")</span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tên giao dịch</label>
                        <input type="text" name="ContactName" class="form-control" value="@Model.ContactName" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="Email" class="form-control" value="@Model.Email" required>
                        <span class="text-danger small">@Html.ValidationMessage("Email")</span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Số điện thoại</label>
                        <input type="tel" name="Phone" class="form-control" value="@Model.Phone" required>
                        <span class="text-danger small">@Html.ValidationMessage("Phone")</span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <input type="text" name="Address" class="form-control" value="@Model.Address">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tỉnh / Thành</label>
                        <select name="Province" class="form-select">
                            <option value="">-- Chọn tỉnh/thành --</option>
                            @foreach (var p in SV22T1020439.BusinessLayers.CommonDataService.ListOfProvinces())
                            {
                                <option value="@p.ProvinceName">@p.ProvinceName</option>
                            }
                        </select>
                    </div>

                    <hr>

                    <div class="mb-3">
                        <label class="form-label">Mật khẩu</label>
                        <input type="password" name="password" class="form-control" required>
                        <span class="text-danger small">@Html.ValidationMessage("password")</span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Xác nhận mật khẩu</label>
                        <input type="password" name="confirmPassword" class="form-control" required>
                        <span class="text-danger small">@Html.ValidationMessage("confirmPassword")</span>
                    </div>

                    <div class="text-danger small mb-3">@Html.ValidationSummary(true)</div>

                    <button type="submit" class="btn btn-primary w-100 py-2 mb-3">Đăng ký ngay</button>
                    
                    <div class="text-center">
                        Đã có tài khoản? <a href="~/Account/Login">Đăng nhập</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
