@model SV22T1020439.Models.OrderSearchResult
@{
    ViewBag.Title = "Lịch sử đơn hàng (Đã hoàn thành & Đã hủy)";
}

<div class="card shadow-sm">
    @* <div class="card-header bg-white py-3">
        <div class="d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="bi bi-clock-history"></i> Lịch sử đơn hàng (Đã hoàn thành & Đã hủy)</h4>
            <a href="~/Order/History" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Quay lại lịch sử
            </a>
        </div>
    </div> *@
    <div class="card-body">
        <form action="~/Order/History" method="get" class="mb-4">
            <div class="row g-2">
                <div class="col-md-4">
                    <select name="status" class="form-select">
                        <option value="-1" selected="@(Model.Status == -1 ? "selected" : null)">Tất cả</option>
                        <option value="3" selected="@(Model.Status == 3 ? "selected" : null)">Hoàn thành</option>
                        <option value="4" selected="@(Model.Status == 4 ? "selected" : null)">Đã hủy</option>
                    </select>
                </div>
                <div class="col-md-8">
                    <div class="input-group">
                        <input type="text" name="searchValue" class="form-control" placeholder="Tìm kiếm đơn hàng..." value="@Model.SearchValue">
                        <button class="btn btn-primary" type="submit">Tìm kiếm</button>
                    </div>
                </div>
                @* <div class="col-md-2">
                    <a href="~/Order/History" class="btn btn-outline-secondary w-100">Xóa bộ lọc</a>
                </div> *@
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th class="text-center">Mã ĐH</th>
                        <th>Ngày lập</th>
                        <th>Địa chỉ giao hàng</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Data.Any())
                    {
                        foreach (var item in Model.Data)
                        {
                            <tr>
                                <td class="text-center fw-bold">#@item.OrderID</td>
                                <td>@item.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <small class="d-block text-truncate" style="max-width: 300px;">
                                        @item.DeliveryAddress, @item.DeliveryProvince
                                    </small>
                                </td>
                                <td class="text-center">
                                    @switch (item.Status)
                                    {
                                        case 0: <span class="badge bg-secondary">Đơn mới</span> break;
                                        case 1: <span class="badge bg-warning">Đã duyệt</span> break;
                                        case 2: <span class="badge bg-info">Đang giao</span> break;
                                        case 3: <span class="badge bg-success">Hoàn thành</span> break;
                                        case 4: <span class="badge bg-danger">Đã hủy</span> break;
                                    }
                                </td>
                                <td class="text-center">
                                    <a href="~/Order/Details/@item.OrderID" class="btn btn-sm btn-outline-primary">
                                        Chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">
                                Bạn chưa có đơn hàng nào
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.PageCount > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    @for (int p = 1; p <= Model.PageCount; p++)
                    {
                        <li class="page-item @(p == Model.Page ? "active" : "")">
                            <a class="page-link" href="~/Order/History?page=@p&searchValue=@Model.SearchValue&status=@Model.Status">@p</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>
