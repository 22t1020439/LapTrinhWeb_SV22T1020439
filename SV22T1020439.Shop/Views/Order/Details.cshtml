@model SV22T1020439.Models.Order
@{
    ViewBag.Title = "Chi tiết đơn hàng #" + Model.OrderID;
    bool canEdit = Model.Status == 0;
}

<div class="card shadow-sm mb-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-info-circle"></i> Đơn hàng #@Model.OrderID</h5>
        <span class="badge @(Model.Status == 4 ? "bg-success" : (Model.Status < 0 ? "bg-danger" : "bg-warning text-dark")) fs-6">
            @switch (Model.Status)
            {
                case 0: <span>Đơn mới</span> break;
                case 1: <span>Đã duyệt</span> break;
                case 2: <span>Đang giao hàng</span> break;
                case 3: <span>Hoàn thành</span> break;
                case 4: <span>Đã hủy</span> break;
            }
        </span>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(TempData["Message"]?.ToString()))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Message"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        
        @if (!string.IsNullOrEmpty(TempData["ErrorMessage"]?.ToString()))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        <div class="row">
            <div class="col-md-6">
                <p><strong>Ngày lập:</strong> @Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</p>
                <p><strong>Khách hàng:</strong> @Model.CustomerName</p>
                <p><strong>Địa chỉ giao:</strong> @Model.DeliveryAddress, @Model.DeliveryProvince</p>
            </div>
            <div class="col-md-6">
                <p><strong>Người giao hàng:</strong> @(Model.ShipperName ?? "Chưa cập nhật")</p>
                <p><strong>Ngày giao:</strong> @(Model.ShippedTime?.ToString("dd/MM/yyyy HH:mm") ?? "---")</p>
                <p><strong>Ngày hoàn tất:</strong> @(Model.FinishedTime?.ToString("dd/MM/yyyy HH:mm") ?? "---")</p>
            </div>
        </div>

        <form asp-action="UpdateAllDetails" method="post" id="updateForm">
            <input type="hidden" name="orderId" value="@Model.OrderID" />
            
            <div class="table-responsive mt-4">
                <table class="table table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Sản phẩm</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-end">Thành tiền</th>
                            @if (canEdit)
                            {
                                <th class="text-center">Thao tác</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Details.Count; i++)
                        {
                            var item = Model.Details[i];
                            <tr>
                                <td>@item.ProductName</td>
                                <td class="text-center">
                                    @if (canEdit)
                                    {
                                        <input type="hidden" name="details[@i].ProductID" value="@item.ProductID" />
                                        <input type="hidden" name="details[@i].SalePrice" value="@item.SalePrice" />
                                        <input type="number" name="details[@i].Quantity" class="form-control form-control-sm text-center" 
                                               value="@item.Quantity" min="1" style="width: 80px;" />
                                    }
                                    else
                                    {
                                        @item.Quantity
                                    }
                                </td>
                                <td class="text-end">@item.SalePrice.ToString("N0") đ</td>
                                <td class="text-end fw-bold">@((item.Quantity * item.SalePrice).ToString("N0")) đ</td>
                                @if (canEdit)
                                {
                                    <td class="text-center">
                                        <a href="~/Order/DeleteDetail?orderId=@Model.OrderID&productId=@item.ProductID" class="btn btn-sm btn-outline-danger"
                                           onclick="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này khỏi đơn hàng?')">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="fs-5">
                            <td colspan="@(canEdit ? 4 : 3)" class="text-end fw-bold">Tổng cộng:</td>
                            <td class="text-end text-danger fw-bold">@Model.Details.Sum(x => x.Quantity * x.SalePrice).ToString("N0") đ</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
            
            @if (canEdit)
            {
                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle"></i> Cập nhật số lượng
                    </button>
                    <a href="~/Order/DonHang" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại đơn hàng
                    </a>
                </div>
            }
            else
            {
                <div class="mt-3">
                    <a href="~/Order/DonHang" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại đơn hàng
                    </a>
                </div>
            }
        </form>
    </div>
</div>
