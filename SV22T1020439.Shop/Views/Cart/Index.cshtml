@model List<SV22T1020439.Models.CartItem>
@{
    ViewBag.Title = "Giỏ hàng";
}

<div class="card">
    <div class="card-header bg-white">
        <h4 class="mb-0"><i class="bi bi-cart3"></i> Giỏ hàng của bạn</h4>
    </div>
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 100px">Ảnh</th>
                            <th>Sản phẩm</th>
                            <th class="text-center" style="width: 150px">Số lượng</th>
                            <th class="text-end" style="width: 150px">Đơn giá</th>
                            <th class="text-end" style="width: 150px">Thành tiền</th>
                            <th class="text-center" style="width: 80px">Xóa</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <img src="@(string.IsNullOrEmpty(item.Photo) ? "/images/products/default.png?v=" + DateTime.Now.Ticks : "/images/products/" + item.Photo)" 
                                         class="img-thumbnail" style="max-height: 60px"
                                         onerror="this.src='/images/products/default.png?v=@DateTime.Now.Ticks'; this.onerror=null;">
                                </td>
                                <td>
                                    <strong>@item.ProductName</strong><br>
                                    <small class="text-muted">Đơn vị: @item.Unit</small>
                                </td>
                                <td>
                                    <div class="input-group input-group-sm">
                                        <button class="btn btn-outline-secondary" type="button" onclick="changeQty(@item.ProductID, -1)">-</button>
                                        <input type="number" min="1" class="form-control text-center qty-input" value="@item.Quantity" data-productid="@item.ProductID" />
                                        <button class="btn btn-outline-secondary" type="button" onclick="changeQty(@item.ProductID, 1)">+</button>
                                    </div>
                                </td>
                                <td class="text-end">@item.SalePrice.ToString("N0") đ</td>
                                <td class="text-end fw-bold">@item.TotalPrice.ToString("N0") đ</td>
                                <td class="text-center">
                                    <a href="~/Cart/RemoveFromCart?productId=@item.ProductID" class="btn btn-sm btn-outline-danger" onclick="return">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="fs-5">
                            <td colspan="4" class="text-end fw-bold">Tổng tiền:</td>
                            <td class="text-end text-danger fw-bold">@Model.Sum(x => x.TotalPrice).ToString("N0") đ</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a href="~/Home/Index" class="btn btn-outline-primary">
                    <i class="bi bi-arrow-left"></i> Tiếp tục mua hàng
                </a>
                <div>
                    <a href="~/Cart/ClearCart" class="btn btn-outline-danger me-2" onclick="return confirm('Xóa toàn bộ giỏ hàng?')">
                        Xóa giỏ hàng
                    </a>
                    <a href="~/Order/Checkout" class="btn btn-primary btn-lg">
                        Tiến hành đặt hàng <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-cart-x fs-1 text-muted"></i>
                <p class="mt-3 fs-5 text-muted">Giỏ hàng của bạn đang trống</p>
                <a href="~/Home/Index" class="btn btn-primary mt-3">
                    Quay lại cửa hàng
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function updateQuantityOnServer(productId, quantity) {
            $.ajax({
                url: '/Cart/UpdateQuantity',
                type: 'POST',
                data: { productId: productId, quantity: quantity },
                success: function(result) {
                    if (result.success) {
                        location.reload();
                    } else {
                        alert(result.message || 'Cập nhật số lượng thất bại');
                    }
                }
            });
        }

        function changeQty(productId, delta) {
            var $input = $('.qty-input[data-productid="' + productId + '"]');
            var current = parseInt($input.val()) || 0;
            var next = current + delta;
            if (next < 1) {
                if (confirm('Xóa sản phẩm này khỏi giỏ hàng?')) {
                    location.href = '/Cart/RemoveFromCart?productId=' + productId;
                }
                return;
            }
            $input.val(next);
            updateQuantityOnServer(productId, next);
        }

        $(function() {
            // when user changes input manually, validate and update
            $('.qty-input').on('change', function() {
                var val = parseInt($(this).val()) || 0;
                var productId = $(this).data('productid');
                if (val < 1) {
                    $(this).val(1);
                    val = 1;
                }
                updateQuantityOnServer(productId, val);
            });
        });
    </script>
}
