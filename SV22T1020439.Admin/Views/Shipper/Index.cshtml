@model SV22T1020439.Models.PaginationSearchResult<SV22T1020439.Models.Shipper>
@{
    ViewBag.Title = "Quản lý Người giao hàng";
}
@section PageToolBar {
    <a href="~/Shipper/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}
<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" action="~/Shipper" method="get">
            <div class="input-group">
                <input type="text" name="searchValue"
                       class="form-control"
                       placeholder="Tên người giao hàng..." autofocus value="@Model.SearchValue" />
                <button class="btn btn-info d-flex align-items-center" type="submit">
                    <i class="bi bi-search me-1"></i> Tìm
                </button>
            </div>
        </form>
    </div>
</div>

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> người giao hàng
</div>

<div class="card shadow-sm border">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="text-center" style="width: 60%;">Tên người giao hàng</th>
                        <th class="text-center" style="width: 25%;">Điện thoại</th>
                        <th class="text-center" style="width: 15%;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Data != null && Model.Data.Any())
                    {
                        foreach (var item in Model.Data)
                        {
                            <tr>
                                <td class="ps-3">@item.ShipperName</td>
                                <td class="text-center">@item.Phone</td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-1">
                                        <a href="~/Shipper/Edit/@item.ShipperID" class="btn btn-xs btn-primary d-flex align-items-center px-2 py-1">
                                            <i class="bi bi-pencil-square me-1 small"></i> <span class="small">Sửa</span>
                                        </a>
                                        <a href="~/Shipper/Delete/@item.ShipperID" class="btn btn-xs btn-danger d-flex align-items-center px-2 py-1">
                                            <i class="bi bi-trash me-1 small"></i> <span class="small">Xóa</span>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center py-4 text-muted">
                                Không tìm thấy người giao hàng nào phù hợp
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card-footer text-center">
        <ul class="pagination justify-content-center mb-0">
            @for (int p = 1; p <= Model.PageCount; p++)
            {
                if (p == Model.Page)
                {
                    <li class="page-item active"><a class="page-link" href="#">@p</a></li>
                }
                else
                {
                    <li class="page-item"><a class="page-link" href="~/Shipper?page=@p&searchValue=@Model.SearchValue">@p</a></li>
                }
            }
        </ul>
    </div>
</div>
