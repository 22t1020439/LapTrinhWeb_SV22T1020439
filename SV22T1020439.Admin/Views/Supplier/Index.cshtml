@model SV22T1020439.Models.PaginationSearchResult<SV22T1020439.Models.Supplier>
@{
    ViewBag.Title = "Quản lý Nhà cung cấp";
}
@section PageToolBar {
    <a href="~/Supplier/Create" class="btn btn-primary d-flex align-items-center ms-1">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}
<div class="card mb-3 shadow-sm">
    <div class="card-body">
        <form id="formSearch" action="~/Supplier" method="get">
            <div class="row g-2">
                <div class="col-md-10">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text" name="searchValue"
                               class="form-control border-start-0 ps-0"
                               placeholder="Tìm kiếm theo tên nhà cung cấp, tên giao dịch, điện thoại hoặc email..." 
                               autofocus value="@Model.SearchValue" />
                    </div>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-info w-100 fw-bold" type="submit">
                        <i class="bi bi-filter me-1"></i> Tìm
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="d-flex align-items-center mb-3">
    <div class="flex-grow-1 text-muted">
        <i class="bi bi-info-circle me-1"></i>
        Tìm thấy <strong>@Model.RowCount.ToString("N0")</strong> nhà cung cấp trong tổng số <strong>@Model.PageCount</strong> trang
    </div>
</div>

<div class="card shadow-sm border">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="text-center" style="width: 20%;">Tên nhà cung cấp</th>
                        <th class="text-center" style="width: 15%;">Tên giao dịch</th>
                        <th class="text-center" style="width: 12%;">Điện thoại</th>
                        <th class="text-center" style="width: 18%;">Email</th>
                        <th class="text-center" style="width: 15%;">Địa chỉ</th>
                        <th class="text-center" style="width: 10%;">Tỉnh / Thành</th>
                        <th class="text-center" style="width: 10%;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Data != null && Model.Data.Any())
                    {
                        foreach (var item in Model.Data)
                        {
                            <tr>
                                <td>@item.SupplierName</td>
                                <td class="text-center">@item.ContactName</td>
                                <td class="text-center">@item.Phone</td>
                                <td class="text-center">@item.Email</td>
                                <td class="text-center">@item.Address</td>
                                <td class="text-center">@item.Province</td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-1">
                                        <a href="~/Supplier/Edit/@item.SupplierID" class="btn btn-xs btn-primary d-flex align-items-center px-2 py-1">
                                            <i class="bi bi-pencil-square me-1 small"></i> <span class="small">Sửa</span>
                                        </a>
                                        <a href="~/Supplier/Delete/@item.SupplierID" class="btn btn-xs btn-danger d-flex align-items-center px-2 py-1">
                                            <i class="bi bi-trash me-1 small"></i> <span class="small">Xóa</span>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">
                                Không tìm thấy nhà cung cấp nào phù hợp
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (Model.PageCount > 1)
    {
        <div class="card-footer bg-white border-top-0 py-3">
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm justify-content-center mb-0">
                    <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                        <a class="page-link shadow-none" href="~/Supplier?page=1&searchValue=@Model.SearchValue"><i class="bi bi-chevron-double-left small"></i></a>
                    </li>
                    @for (int p = 1; p <= Model.PageCount; p++)
                    {
                        if (p == Model.Page)
                        {
                            <li class="page-item active" aria-current="page"><span class="page-link shadow-none border-primary bg-primary">@p</span></li>
                        }
                        else
                        {
                            <li class="page-item"><a class="page-link shadow-none" href="~/Supplier?page=@p&searchValue=@Model.SearchValue">@p</a></li>
                        }
                    }
                    <li class="page-item @(Model.Page >= Model.PageCount ? "disabled" : "")">
                        <a class="page-link shadow-none" href="~/Supplier?page=@Model.PageCount&searchValue=@Model.SearchValue"><i class="bi bi-chevron-double-right small"></i></a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>



