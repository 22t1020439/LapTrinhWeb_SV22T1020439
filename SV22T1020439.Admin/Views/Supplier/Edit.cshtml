@model SV22T1020439.Models.Supplier
@{
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>

    <a href="~/Supplier" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-truck me-2"></i>
                    Thông tin nhà cung cấp
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" action="~/Supplier/Save" method="post">
                    <input type="hidden" name="SupplierID" value="@Model.SupplierID" />
                    
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Tên nhà cung cấp</label>
                        <div class="col-sm-9">
                            <input type="text" name="SupplierName"
                                   class="form-control"
                                   placeholder="Nhập tên nhà cung cấp" autofocus value="@Model.SupplierName" />
                            @Html.ValidationMessage(nameof(Model.SupplierName), new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Tên giao dịch</label>
                        <div class="col-sm-9">
                            <input type="text" name="ContactName"
                                   class="form-control"
                                   placeholder="Nhập tên giao dịch" value="@Model.ContactName" />
                            @Html.ValidationMessage(nameof(Model.ContactName), new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Điện thoại</label>
                        <div class="col-sm-3">
                            <input type="tel" name="Phone"
                                   class="form-control"
                                   placeholder="Số điện thoại" value="@Model.Phone" />
                        </div>
                        <label class="col-sm-1 col-form-label text-end">Email</label>
                        <div class="col-sm-5">
                            <input type="email" name="Email"
                                   class="form-control"
                                   placeholder="Địa chỉ email" value="@Model.Email" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Địa chỉ</label>
                        <div class="col-sm-9">
                            <textarea name="Address" class="form-control"
                                      rows="3"
                                      placeholder="Địa chỉ chi tiết">@Model.Address</textarea>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Tỉnh / Thành</label>
                        <div class="col-sm-9">
                            <select name="Province" class="form-select">
                                <option value="">-- Chọn tỉnh / thành --</option>
                                @foreach (var p in SV22T1020439.BusinessLayers.CommonDataService.ListOfProvinces())
                                {
                                    if (p.ProvinceName == Model.Province)
                                    {
                                        <option value="@p.ProvinceName" selected>@p.ProvinceName</option>
                                    }
                                    else
                                    {
                                        <option value="@p.ProvinceName">@p.ProvinceName</option>
                                    }
                                }
                            </select>
                            @Html.ValidationMessage(nameof(Model.Province), new { @class = "text-danger" })
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
