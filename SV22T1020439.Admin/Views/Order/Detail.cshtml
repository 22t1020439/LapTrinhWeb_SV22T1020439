@model SV22T1020439.Models.Order
@{
    ViewBag.Title = "Chi tiết đơn hàng";
}

@section PageToolBar {
    <div class="btn-group">
        <button type="button"
                class="btn btn-primary dropdown-toggle"
                data-bs-toggle="dropdown">
            <i class="bi bi-gear me-1"></i>
            Xử lý đơn hàng
        </button>
        <ul class="dropdown-menu">
            @if (Model.Status == 0)
            {
                <li><a class="dropdown-item" href="~/Order/Accept/@Model.OrderID" onclick="return confirm('Duyệt đơn hàng này?')">Duyệt đơn hàng</a></li>
            }
            @if (Model.Status == 1)
            {
                <li><a class="dropdown-item open-modal" href="~/Order/Shipping/@Model.OrderID">Chuyển/Cập nhật giao hàng</a></li>
            }
            @if (Model.Status == 2)
            {
                <li><a class="dropdown-item" href="~/Order/Finish/@Model.OrderID" onclick="return confirm('Xác nhận đã hoàn tất đơn hàng này?')">Hoàn tất đơn hàng</a></li>
                <li><a class="dropdown-item text-warning" href="~/Order/Reject/@Model.OrderID" onclick="return confirm('Bạn có chắc chắn muốn từ chối đơn hàng này?')">Từ chối đơn hàng</a></li>
            }
            <li><hr class="dropdown-divider"></li>
            @if (Model.Status == 0 || Model.Status == 1 || Model.Status == 2)
            {
                <li><a class="dropdown-item text-danger" href="~/Order/Cancel/@Model.OrderID" onclick="return confirm('Bạn có chắc chắn muốn hủy đơn hàng này?')">Hủy đơn hàng</a></li>
            }
        </ul>
    </div>

    @if (Model.Status == 0 || Model.Status == 4 || Model.Status == 5)
    {
        <a href="~/Order/Delete/@Model.OrderID"
           class="btn btn-danger ms-1 open-modal">
            <i class="bi bi-trash"></i>
            Xóa
        </a>
    }

    <a href="~/Order" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<!-- TRẠNG THÁI ĐƠN HÀNG -->
<div class="alert @(Model.Status == 3 ? "alert-success" : (Model.Status >= 4 ? "alert-danger" : "alert-info")) d-flex align-items-center mb-3">
    <i class="bi @(Model.Status == 3 ? "bi-check-circle-fill" : (Model.Status >= 4 ? "bi-x-circle-fill" : "bi-info-circle-fill")) fs-4 me-2"></i>
    <div>
        <strong>Trạng thái đơn hàng:</strong>
        @switch (Model.Status)
        {
            case 0: <span>Đơn mới</span> break;
            case 1: <span>Đã duyệt</span> break;
            case 2: <span>Đang giao</span> break;
            case 3: <span>Hoàn thành lúc <b>@Model.FinishedTime?.ToString("dd/MM/yyyy HH:mm")</b></span> break;
            case 4: <span>Đã hủy lúc <b>@Model.FinishedTime?.ToString("dd/MM/yyyy HH:mm")</b></span> break;
            case 5: <span>Từ chối lúc <b>@Model.FinishedTime?.ToString("dd/MM/yyyy HH:mm")</b></span> break;
        }
    </div>
</div>

<!-- THÔNG TIN ĐƠN HÀNG -->
<div class="card card-primary card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-receipt me-2"></i>
            Thông tin đơn hàng
        </h5>
    </div>

    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Mã đơn hàng</div>
            <div class="col-md-3">@Model.OrderID</div>

            <div class="col-md-3 fw-bold">Ngày lập</div>
            <div class="col-md-3">@Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</div>
        </div>

        <div class="row">
            <div class="col-md-3 fw-bold">Nhân viên phụ trách</div>
            <div class="col-md-3">@Model.EmployeeName</div>

            <div class="col-md-3 fw-bold">Ngày nhận đơn</div>
            <div class="col-md-3">@Model.AcceptTime?.ToString("dd/MM/yyyy HH:mm")</div>
        </div>
    </div>
</div>

<!-- THÔNG TIN KHÁCH HÀNG -->
<div class="card card-info card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-person me-2"></i>
            Thông tin khách hàng
        </h5>
    </div>

    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Khách hàng</div>
            <div class="col-md-3">@Model.CustomerName</div>

            <div class="col-md-3 fw-bold">Tên giao dịch</div>
            <div class="col-md-3">@Model.CustomerContactName</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Email</div>
            <div class="col-md-9">@Model.CustomerEmail</div>
        </div>

        <div class="row">
            <div class="col-md-3 fw-bold">Địa chỉ</div>
            <div class="col-md-9">@Model.CustomerAddress</div>
        </div>
    </div>
</div>

<!-- THÔNG TIN GIAO HÀNG -->
<div class="card card-success card-outline mb-3">
    <div class="card-header">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">
                <i class="bi bi-truck me-2"></i>
                Thông tin giao hàng
            </h5>
            @if (Model.Status == 1)
            {
                <a href="~/Order/Shipping/@Model.OrderID" class="btn btn-sm btn-outline-success open-modal">
                    <i class="bi bi-pencil-square"></i> Cập nhật
                </a>
            }
        </div>
    </div>

    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Người giao hàng</div>
            <div class="col-md-3">@Model.ShipperName</div>

            <div class="col-md-3 fw-bold">Điện thoại</div>
            <div class="col-md-3">@Model.ShipperPhone</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Địa chỉ giao hàng</div>
            <div class="col-md-9">@Model.DeliveryAddress</div>
        </div>

        <div class="row">
            <div class="col-md-3 fw-bold">Tỉnh / Thành</div>
            <div class="col-md-9">@Model.DeliveryProvince</div>
        </div>
    </div>
</div>

<!-- DANH SÁCH MẶT HÀNG -->
<div class="card card-secondary card-outline">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-box-seam me-2"></i>
            Danh sách mặt hàng
        </h5>
    </div>

    <div class="card-body table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-secondary text-center">
                <tr>
                    <th>STT</th>
                    <th>Tên hàng</th>
                    <th>ĐVT</th>
                    <th>Số lượng</th>
                    <th>Giá</th>
                    <th>Thành tiền</th>
                    <th style="width:90px"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Details != null && Model.Details.Any())
                {
                    int i = 0;
                    foreach (var item in Model.Details)
                    {
                        i++;
                        <tr>
                            <td class="text-center">@i</td>
                            <td>@item.ProductName</td>
                            <td class="text-center">@item.Unit</td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-end">@item.SalePrice.ToString("N0")</td>
                            <td class="text-end">@((item.Quantity * item.SalePrice).ToString("N0"))</td>
                            <td class="text-end">
                                @if (Model.Status == 0 || Model.Status == 1)
                                {
                                    <a href="~/Order/EditDetail/@Model.OrderID?productId=@item.ProductID" class="btn btn-sm btn-primary open-modal">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="~/Order/DeleteDetail/@Model.OrderID?productId=@item.ProductID" class="btn btn-sm btn-danger" onclick="return confirm('Xóa mặt hàng này khỏi đơn hàng?')">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="5" class="text-end">Tổng cộng</th>
                    <th class="text-end">@(Model.Details?.Sum(x => x.Quantity * x.SalePrice).ToString("N0") ?? "0")</th>
                    <th></th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@section Styles {
    <style>
        .card-body .row {
            border-bottom: 1px dotted #646464;
        }
    </style>
}