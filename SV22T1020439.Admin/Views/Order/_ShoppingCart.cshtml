@model List<SV22T1020439.Models.CartItem>
@{
    Layout = null;
}

<table class="table table-bordered table-hover align-middle">
    <thead class="table-success">
        <tr>
            <th class="text-center">#</th>
            <th style="width:auto">Tên hàng</th>
            <th class="text-center" style="width:100px">ĐVT</th>
            <th class="text-center" style="width:100px">SL</th>
            <th class="text-end" style="width:150px">Giá</th>
            <th class="text-end" style="width:150px">Thành tiền</th>
            <th style="width:80px"></th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            int i = 0;
            foreach (var item in Model)
            {
                i++;
                <tr>
                    <td class="text-center">@i</td>
                    <td>@item.ProductName</td>
                    <td class="text-center">@item.Unit</td>
                    <td class="text-center">@item.Quantity</td>
                    <td class="text-end">@item.SalePrice.ToString("N0")</td>
                    <td class="text-end">@item.TotalPrice.ToString("N0")</td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-sm btn-primary open-modal" href="~/Order/EditCartItem?productId=@item.ProductID">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a class="btn btn-sm btn-danger ajax-link" href="~/Order/RemoveFromCart?productId=@item.ProductID" 
                           data-confirm="Xóa mặt hàng này khỏi giỏ hàng?">
                            <i class="bi bi-dash"></i>
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center">Giỏ hàng trống</td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr>
            <th colspan="5" class="text-end">Tổng cộng:</th>
            <th class="text-end">@Model.Sum(x => x.TotalPrice).ToString("N0")</th>
            <th></th>
        </tr>
    </tfoot>
</table>

<div class="text-end">
    <a class="btn btn-sm btn-danger mt-2 ajax-link"                               
       href="~/Order/ClearCart" data-confirm="Bạn có chắc chắn muốn xóa toàn bộ giỏ hàng?">
        <i class="bi bi-trash"></i>
        Xóa giỏ hàng
    </a>
</div>

<script>
    $(document).ready(function() {
        $('.ajax-link').click(function(e) {
            e.preventDefault();
            var url = $(this).attr('href');
            var confirmMsg = $(this).data('confirm');
            if (confirmMsg && !confirm(confirmMsg)) return;

            $.ajax({
                url: url,
                type: 'GET',
                success: function() {
                    showShoppingCart();
                }
            });
        });
    });
</script>
