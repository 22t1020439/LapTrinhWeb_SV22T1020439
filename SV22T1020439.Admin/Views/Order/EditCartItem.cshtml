@model SV22T1020439.Models.CartItem
@{
    Layout = null;
}

<div class="modal-dialog">
    <div class="modal-content">
        <form action="~/Order/UpdateCartItem" method="post" id="formEditCartItem">
            <input type="hidden" name="productId" value="@Model.ProductID" />
            
            <div class="modal-header">
                <h5 class="modal-title">Cập nhật mặt hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Tên mặt hàng:</label>
                    <p class="form-control-plaintext fw-bold">@Model.ProductName</p>
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Đơn vị tính:</label>
                    <p class="form-control-plaintext">@Model.Unit</p>
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Số lượng:</label>
                    <input type="number" name="quantity" class="form-control" value="@Model.Quantity" min="1" required />
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Đơn giá:</label>
                    <input type="text" name="salePrice" class="form-control money-input" value="@Model.SalePrice.ToString("N0")" required />
                </div>
            </div>
            
            <div class="modal-footer">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save"></i> Cập nhật
                </button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </form>
    </div>
</div>

<script>
    $(document).ready(function () {
        $('#formEditCartItem').submit(function (e) {
            e.preventDefault();
            
            var url = $(this).attr('action');
            var method = $(this).attr('method');
            var data = $(this).serialize();
            
            $.ajax({
                url: url,
                type: method,
                data: data,
                success: function (result) {
                    if (result.success) {
                        $('#modal-container').modal('hide');
                        // Load lại giỏ hàng (giả sử có hàm này ở view cha)
                        if (typeof showShoppingCart === "function") {
                            showShoppingCart();
                        } else {
                            location.reload();
                        }
                    } else {
                        alert(result.message);
                    }
                }
            });
        });

        // Initialize money input mask if available
        if (typeof setupMoneyInput === "function") {
            setupMoneyInput('.money-input');
        }
    });
</script>
