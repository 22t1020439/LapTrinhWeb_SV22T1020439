@model SV22T1020439.Models.Customer
@{
    ViewBag.Title = "Xóa khách hàng";
}

@section PageToolBar {
    @if (ViewBag.IsUsed == false)
    {
        <button type="submit" form="formDelete" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i>
            Xóa
        </button>
    }

    <a href="~/Customer" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-danger card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0 text-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Xác nhận xóa khách hàng
                </h5>
            </div>

            <div class="card-body">
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger">
                        @TempData["ErrorMessage"]
                    </div>
                }

                <form id="formDelete" action="~/Customer/Delete/@Model.CustomerID" method="post">
                    @if (ViewBag.IsUsed)
                    {
                        <div class="alert alert-danger d-flex align-items-center">
                            <i class="bi bi-x-circle me-2"></i>
                            Khách hàng này hiện đang có dữ liệu liên quan (đơn hàng), không được phép xóa.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning d-flex align-items-center">
                            <i class="bi bi-info-circle me-2"></i>
                            Bạn có chắc chắn muốn xóa khách hàng sau không?
                        </div>
                    }

                    <div class="row">
                        <div class="col-md-12">
                            <dl class="row mb-0">
                                <dt class="col-sm-4">Tên khách hàng</dt>
                                <dd class="col-sm-8">@Model.CustomerName</dd>

                                <dt class="col-sm-4">Tên giao dịch</dt>
                                <dd class="col-sm-8">@Model.ContactName</dd>

                                <dt class="col-sm-4">Điện thoại</dt>
                                <dd class="col-sm-8">@Model.Phone</dd>

                                <dt class="col-sm-4">Email</dt>
                                <dd class="col-sm-8">@Model.Email</dd>

                                <dt class="col-sm-4">Địa chỉ</dt>
                                <dd class="col-sm-8">@Model.Address</dd>

                                <dt class="col-sm-4">Tỉnh / Thành</dt>
                                <dd class="col-sm-8">@Model.Province</dd>

                                <dt class="col-sm-4">Trạng thái</dt>
                                <dd class="col-sm-8">
                                    @if (Model.IsLocked)
                                    {
                                        <span class="badge bg-danger">Bị khóa</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Hoạt động</span>
                                    }
                                </dd>
                            </dl>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
