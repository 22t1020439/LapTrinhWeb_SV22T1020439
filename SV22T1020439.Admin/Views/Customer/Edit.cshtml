@model SV22T1020439.Models.Customer
@{
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>    
    <a href="~/Customer" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-people me-2"></i>
                    Thông tin khách hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" action="~/Customer/Save" method="post">
                    <input type="hidden" name="CustomerID" value="@Model.CustomerID" />

                    <div class="row align-items-end">
                        <div class="col-md-5 mb-3">
                            <label class="form-label">Tên khách hàng</label>
                            <input type="text" name="CustomerName"
                                   class="form-control"
                                   placeholder="Nhập tên khách hàng" autofocus value="@Model.CustomerName" />
                            @Html.ValidationMessage(nameof(Model.CustomerName), new { @class = "text-danger" })
                        </div>
                        <div class="col-md-5 mb-3">
                            <label class="form-label">Tên giao dịch</label>
                            <input type="text" name="ContactName"
                                   class="form-control"
                                   placeholder="Nhập tên giao dịch" value="@Model.ContactName" />
                            @Html.ValidationMessage(nameof(Model.ContactName), new { @class = "text-danger" })
                        </div>
                        <div class="col-md-2 mb-3">
                            <label class="form-label d-block">Trạng thái</label>
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input"
                                       type="checkbox"
                                       name="IsLocked"
                                       id="IsLocked"
                                       value="true"
                                       @(Model.IsLocked ? "checked" : "") />
                                <label class="form-check-label" for="IsLocked">
                                    Bị khóa
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-5 mb-3">
                            <label class="form-label">Điện thoại</label>
                            <input type="tel" name="Phone"
                                   class="form-control"
                                   placeholder="Nhập số điện thoại" value="@Model.Phone" />
                        </div>

                        <div class="col-md-7 mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" name="Email"
                                   class="form-control"
                                   placeholder="Nhập email" value="@Model.Email" />
                            @Html.ValidationMessage(nameof(Model.Email), new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <textarea name="Address" class="form-control"
                                  rows="3"
                                  placeholder="Nhập địa chỉ">@Model.Address</textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tỉnh / Thành</label>
                        <select name="Province" class="form-select">
                            <option value="">-- Chọn tỉnh / thành --</option>
                            @* <select class="form-select" aps-for="provine" app-item="AppCodes.SelectListHelper.Provine()"> *@
                            @foreach (var p in SV22T1020439.BusinessLayers.CommonDataService.ListOfProvinces())
                            {
                                if (p.ProvinceName == Model.Province)
                                {
                                    <option value="@p.ProvinceName" selected>@p.ProvinceName</option>
                                }
                                else
                                {
                                    <option value="@p.ProvinceName">@p.ProvinceName</option>
                                }
                            }
                        </select>
                        @Html.ValidationMessage(nameof(Model.Province), new { @class = "text-danger" })
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
