@model int
@{
    Layout = null;
    var attributes = SV22T1020439.BusinessLayers.ProductDataService.ListAttributes(Model);
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-success card-outline mt-4">
            <div class="card-header">
                <div class="row">
                    <div class="col">
                        <h6 id="attributes" class="card-title mb-0">
                            <i class="bi bi-list-check me-2"></i>
                            Thuộc tính mặt hàng
                        </h6>
                    </div>
                    <div class="col text-end">
                        <a class="btn btn-sm btn-primary" href="~/Product/EditAttribute/@Model">
                            <i class="bi bi-plus"></i>
                            Thêm thuộc tính
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-1">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th>Tên thuộc tính</th>
                            <th>Giá trị</th>
                            <th style="width:120px" class="text-center">Thứ tự</th>
                            <th style="width:100px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var attr in attributes)
                        {
                            <tr>
                                <td>@attr.AttributeName</td>
                                <td>@attr.AttributeValue</td>
                                <td class="text-center">@attr.DisplayOrder</td>
                                <td class="text-center text-nowrap">
                                    <a class="btn btn-sm btn-primary" href="~/Product/EditAttribute/@Model?attributeId=@attr.AttributeID">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post" action="~/Product/DeleteAttribute/@Model?attributeId=@attr.AttributeID" style="display:inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa thuộc tính này?')">
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
