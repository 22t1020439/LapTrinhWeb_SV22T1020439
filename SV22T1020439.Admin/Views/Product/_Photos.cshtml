@model int
@{
    Layout = null;
    var photos = SV22T1020439.BusinessLayers.ProductDataService.ListPhotos(Model);
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-info card-outline mt-4">
            <div class="card-header">
                <div class="row">
                    <div class="col">
                        <h6 id="photos" class="mb-0">
                            <i class="bi bi-images me-2"></i>
                            Thư viện ảnh
                        </h6>
                    </div>
                    <div class="col text-end">
                        <a class="btn btn-sm btn-primary" href="~/Product/EditPhoto/@Model">
                            <i class="bi bi-plus-circle me-1"></i>
                            Thêm ảnh
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-1">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th style="width:120px">Ảnh</th>
                            <th>Mô tả</th>
                            <th style="width:120px" class="text-center">Thứ tự</th>
                            <th style="width:120px">Hiển thị</th>
                            <th style="width:100px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var photo in photos)
                        {
                            <tr>
                                <td class="text-center">
                                    <img src="~/images/products/@(string.IsNullOrEmpty(photo.Photo) ? "default.png" : photo.Photo)"
                                    class="img-thumbnail"
                                    style="max-height:80px;" />
                                </td>
                                <td>@photo.Description</td>
                                <td class="text-center">@photo.DisplayOrder</td>
                                <td class="text-center">
                                    @if (photo.IsHidden)
                                    {
                                        <span class="badge bg-danger">Ẩn</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Hiện</span>
                                    }
                                </td>
                                <td class="text-center text-nowrap">
                                    <a class="btn btn-sm btn-primary" href="~/Product/EditPhoto/@Model?photoId=@photo.PhotoID">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a class="btn btn-sm btn-danger" href="~/Product/DeletePhoto/@Model?photoId=@photo.PhotoID" onclick="return confirm('Bạn có chắc chắn muốn xóa ảnh này?')">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>