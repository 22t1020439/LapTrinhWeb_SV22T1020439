@model SV22T1020439.Models.Product
@{
    string displayPhoto = Model.Photo;
    if (string.IsNullOrEmpty(displayPhoto))
    {
        var photos = SV22T1020439.BusinessLayers.ProductDataService.ListPhotos(Model.ProductID);
        if (photos != null && photos.Count > 0)
        {
            displayPhoto = photos[0].Photo;
        }
    }
    if (string.IsNullOrEmpty(displayPhoto))
    {
        displayPhoto = "default.png";
    }
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>

    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-box-seam me-2"></i>
                    Thông tin mặt hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" action="~/Product/Save" method="post" enctype="multipart/form-data">
                    <input type="hidden" name="ProductID" value="@Model.ProductID" />

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Tên mặt hàng</label>
                        <div class="col-sm-9">
                            <input type="text" name="ProductName"
                                   class="form-control"
                                   placeholder="Nhập tên mặt hàng" autofocus value="@Model.ProductName" />
                            @Html.ValidationMessage(nameof(Model.ProductName), new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Loại hàng</label>
                        <div class="col-sm-3">
                            <select class="form-select" name="CategoryID">
                                <option value="0">-- Chọn loại hàng --</option>
                                @foreach (var c in SV22T1020439.BusinessLayers.CommonDataService.ListOfCategories())
                                {
                                    if (c.CategoryID == Model.CategoryID)
                                    {
                                        <option value="@c.CategoryID" selected>@c.CategoryName</option>
                                    }
                                    else
                                    {
                                        <option value="@c.CategoryID">@c.CategoryName</option>
                                    }
                                }
                            </select>
                            @Html.ValidationMessage(nameof(Model.CategoryID), new { @class = "text-danger" })
                        </div>

                        <label class="col-sm-2 col-form-label text-end">Nhà cung cấp</label>
                        <div class="col-sm-4">
                            <select class="form-select" name="SupplierID">
                                <option value="0">-- Chọn nhà cung cấp --</option>
                                @foreach (var s in SV22T1020439.BusinessLayers.CommonDataService.ListOfSuppliers())
                                {
                                    if (s.SupplierID == Model.SupplierID)
                                    {
                                        <option value="@s.SupplierID" selected>@s.SupplierName</option>
                                    }
                                    else
                                    {
                                        <option value="@s.SupplierID">@s.SupplierName</option>
                                    }
                                }
                            </select>
                            @Html.ValidationMessage(nameof(Model.SupplierID), new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Đơn vị tính</label>
                        <div class="col-sm-3">
                            <input type="text" name="Unit"
                                   class="form-control"
                                   placeholder="cái, hộp, kg..." value="@Model.Unit" />
                            @Html.ValidationMessage(nameof(Model.Unit), new { @class = "text-danger" })
                        </div>

                        <label class="col-sm-2 col-form-label text-end">Giá</label>
                        <div class="col-sm-4">
                            <input type="text" name="_Price"
                                   class="form-control money-input"
                                   placeholder="Giá bán"
                                   min="0" value="@Model.Price.ToString("N0")" />
                            @Html.ValidationMessage(nameof(Model.Price), new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input"
                                       type="checkbox"
                                       name="IsSelling"
                                       id="IsSelling"
                                       value="true"
                                       @(Model.IsSelling ? "checked" : "") />
                                <label class="form-check-label" for="IsSelling">
                                    Đang bán
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Ảnh</label>
                        <div class="col-sm-9">
                            <input type="hidden" name="Photo" value="@Model.Photo" />
                            <input type="file" name="uploadPhoto"
                                   class="form-control"
                                   accept="image/*"
                                   onchange="document.getElementById('imgPreview').src = window.URL.createObjectURL(this.files[0])" />
                            <div class="mt-2">
                                <img id="imgPreview"
                                     src="~/images/products/@displayPhoto"
                                     class="img-thumbnail"
                                     style="max-height: 160px;" />
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Mô tả</label>
                        <div class="col-sm-9">
                            <textarea name="ProductDescription" class="form-control"
                                      rows="3"
                                      placeholder="Nhập mô tả mặt hàng">@Model.ProductDescription</textarea>
                        </div>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@if (Model.ProductID > 0)
{
    <partial name="_Photos" model="Model.ProductID" />
    <partial name="_Attributes" model="Model.ProductID" />
}