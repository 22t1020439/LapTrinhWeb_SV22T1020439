@model SV22T1020439.Models.Product
@{
    ViewBag.Title = "Xóa mặt hàng";
}

@section PageToolBar {
    @if (ViewBag.IsUsed == false)
    {
        <button type="submit" form="formDelete" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i>
            Xóa
        </button>
    }
    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-danger card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0 text-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Xác nhận xóa mặt hàng
                </h5>
            </div>

            <div class="card-body">
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger">
                        @TempData["ErrorMessage"]
                    </div>
                }

                <form id="formDelete" action="~/Product/Delete/@Model.ProductID" method="post">
                    @if (ViewBag.IsUsed)
                    {
                        <div class="alert alert-danger d-flex align-items-center">
                            <i class="bi bi-x-circle me-2"></i>
                            Mặt hàng này hiện đang có dữ liệu liên quan (đơn hàng), không được phép xóa.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning d-flex align-items-center">
                            <i class="bi bi-info-circle me-2"></i>
                            Bạn có chắc chắn muốn xóa mặt hàng sau không?
                        </div>
                    }

                    <div class="row">
                        <div class="col-md-8">
                            <dl class="row mb-0">
                                <dt class="col-sm-4">Tên mặt hàng</dt>
                                <dd class="col-sm-8">@Model.ProductName</dd>

                                <dt class="col-sm-4">Loại hàng</dt>
                                <dd class="col-sm-8">@(SV22T1020439.BusinessLayers.CommonDataService.GetCategory(Model.CategoryID)?.CategoryName ?? "")</dd>

                                <dt class="col-sm-4">Nhà cung cấp</dt>
                                <dd class="col-sm-8">@(SV22T1020439.BusinessLayers.CommonDataService.GetSupplier(Model.SupplierID)?.SupplierName ?? "")</dd>

                                <dt class="col-sm-4">Đơn vị tính</dt>
                                <dd class="col-sm-8">@Model.Unit</dd>

                                <dt class="col-sm-4">Giá bán</dt>
                                <dd class="col-sm-8">@Model.Price.ToString("N0") đ</dd>

                                <dt class="col-sm-4">Trạng thái</dt>
                                <dd class="col-sm-8">
                                    @if (Model.IsSelling)
                                    {
                                        <span class="badge bg-success">Đang bán</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Ngừng bán</span>
                                    }
                                </dd>

                                <dt class="col-sm-4">Mô tả</dt>
                                <dd class="col-sm-8">
                                    @Model.ProductDescription
                                </dd>
                            </dl>
                        </div>

                        <div class="col-md-4 text-end">
                            <img src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "default.png" : Model.Photo)"
                                 class="img-fluid img-thumbnail"
                                 alt="Ảnh mặt hàng"
                                 style="max-height: 220px;" />
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
