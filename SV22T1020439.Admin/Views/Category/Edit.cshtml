@model SV22T1020439.Models.Category
@{
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>    
    <a href="~/Category" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline shadow-sm">
            <div class="card-header border-0 bg-transparent py-3">
                <h5 class="card-title fw-bold mb-0">
                    <i class="bi bi-tags me-2 text-primary"></i>
                    Thông tin loại hàng
                </h5>
            </div>

            <div class="card-body px-4 pb-4">
                <form id="formEdit" action="~/Category/Save" method="post">
                    @Html.HiddenFor(m => m.CategoryID)

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tên loại hàng</label>
                        <input type="text"
                               name="@nameof(Model.CategoryName)"
                               value="@Model.CategoryName"
                               class="form-control"
                               placeholder="Nhập tên loại hàng" autofocus />
                        @Html.ValidationMessage(nameof(Model.CategoryName), new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mô tả</label>
                        <textarea name="@nameof(Model.Description)"
                                  class="form-control"
                                  rows="4"
                                  placeholder="Nhập mô tả loại hàng">@Model.Description</textarea>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>
