@model SV22T1020439.Models.Category
@{
    ViewBag.Title = "Xóa loại hàng";
}

@section PageToolBar {
    @if (ViewBag.IsUsed == false)
    {
        <button type="submit" form="formDelete" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i>
            Xóa
        </button>
    }
    <a href="~/Category" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-danger card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0 text-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Xác nhận xóa loại hàng
                </h5>
            </div>

            <div class="card-body">
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger">
                        @TempData["ErrorMessage"]
                    </div>
                }

                <form id="formDelete" action="~/Category/Delete/@Model.CategoryID" method="post">
                    @if (ViewBag.IsUsed)
                    {
                        <div class="alert alert-danger d-flex align-items-center">
                            <i class="bi bi-x-circle me-2"></i>
                            Loại hàng này hiện đang được sử dụng cho các mặt hàng, không được phép xóa.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning d-flex align-items-center">
                            <i class="bi bi-info-circle me-2"></i>
                            Bạn có chắc chắn muốn xóa loại hàng sau không?
                        </div>
                    }

                    <div class="row">
                        <div class="col-md-12">
                            <dl class="row mb-0">
                                <dt class="col-sm-4">Tên loại hàng</dt>
                                <dd class="col-sm-8">@Model.CategoryName</dd>

                                <dt class="col-sm-4">Mô tả</dt>
                                <dd class="col-sm-8">@Model.Description</dd>
                            </dl>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
